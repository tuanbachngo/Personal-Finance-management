# ------------------------------
# Dockerized local MySQL
# ------------------------------
# Docker Compose does NOT auto-load .env.docker by default.
# Recommended:
# 1) copy this file to `.env` for plain `docker compose ...` commands, OR
# 2) keep `.env.docker` and always use `--env-file .env.docker`
MYSQL_ROOT_PASSWORD=CHANGE_ME_DOCKER_MYSQL_ROOT_PASSWORD
MYSQL_LOCAL_PORT=3307
STREAMLIT_LOCAL_PORT=8501

# ------------------------------
# App connection inside Docker network
# ------------------------------
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_DATABASE=Personal_Finance

# ------------------------------
# Auth runtime mode
# ------------------------------
AUTH_DEV_MODE=false
AUTH_LOG_OTP_IN_DEV=false

# ------------------------------
# Admin bootstrap (required after reset)
# ------------------------------
PF_ADMIN_EMAIL=tuanbachngo@gmail.com
PF_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
PF_ADMIN_NAME=Ngo Tuan Bach
PF_ADMIN_PHONE=0901000010
PF_ADMIN_RECOVERY_HINT=Your recovery hint here
PF_ADMIN_RECOVERY_ANSWER=CHANGE_ME_RECOVERY_ANSWER

# Optional: seed sample USER passwords for easier login testing.
PF_SEED_SAMPLE_USER_PASSWORD=
PF_FORCE_RESET_SAMPLE_PASSWORDS=false

# ------------------------------
# Smoke test credentials
# ------------------------------
SMOKE_ADMIN_EMAIL=tuanbachngo@gmail.com
SMOKE_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
