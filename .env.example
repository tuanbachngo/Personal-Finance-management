# ------------------------------
# MySQL connection (required)
# ------------------------------
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=CHANGE_ME_MYSQL_PASSWORD
MYSQL_DATABASE=Personal_Finance

# ------------------------------
# Auth runtime mode
# ------------------------------
AUTH_DEV_MODE=false
AUTH_LOG_OTP_IN_DEV=true

# ------------------------------
# Local auth bootstrap (required for bootstrap script)
# ------------------------------
PF_ADMIN_EMAIL=admin@example.com
PF_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
PF_ADMIN_NAME=System Admin
PF_ADMIN_PHONE=
PF_ADMIN_RECOVERY_HINT=
PF_ADMIN_RECOVERY_ANSWER=

# Optional: seed a default password for sample USER accounts.
# Leave empty to skip.
PF_SEED_SAMPLE_USER_PASSWORD=

# Optional: when true, overwrite existing USER passwords while seeding.
PF_FORCE_RESET_SAMPLE_PASSWORDS=false

# ------------------------------
# Smoke test credentials
# ------------------------------
SMOKE_ADMIN_EMAIL=admin@example.com
SMOKE_ADMIN_PASSWORD=CHANGE_ME_SMOKE_ADMIN_PASSWORD
