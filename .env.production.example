# ------------------------------
# Public app / reverse proxy
# ------------------------------
APP_DOMAIN=finance.example.com
CADDY_EMAIL=admin@example.com

# ------------------------------
# Managed / remote MySQL
# Keep database name fixed.
# ------------------------------
MYSQL_HOST=your-managed-mysql-host
MYSQL_PORT=3306
MYSQL_USER=your_app_user
MYSQL_PASSWORD=CHANGE_ME_MYSQL_PASSWORD
MYSQL_DATABASE=Personal_Finance

# ------------------------------
# Production auth runtime
# ------------------------------
AUTH_DEV_MODE=false
AUTH_LOG_OTP_IN_DEV=false

# ------------------------------
# Admin bootstrap
# ------------------------------
PF_ADMIN_EMAIL=tuanbachngo@gmail.com
PF_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
PF_ADMIN_NAME=Ngo Tuan Bach
PF_ADMIN_PHONE=0901000010
PF_ADMIN_RECOVERY_HINT=CHANGE_ME_RECOVERY_HINT
PF_ADMIN_RECOVERY_ANSWER=CHANGE_ME_RECOVERY_ANSWER

# Optional sample-user password seeding for demo accounts.
PF_SEED_SAMPLE_USER_PASSWORD=
PF_FORCE_RESET_SAMPLE_PASSWORDS=false

# ------------------------------
# Smoke test login
# ------------------------------
SMOKE_ADMIN_EMAIL=tuanbachngo@gmail.com
SMOKE_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
